---
import { Image } from "astro:assets";
import Container from "./Container.astro";
import Button from "./Button.astro";
import Icon from "./Icon.astro";
import heroPortrait from "../assets/img/sussana.webp";
import { getTranslations, getWhatsappUrl, type Lang } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const translations = getTranslations(lang);
const t = translations.hero;
const whatsappUrl = getWhatsappUrl(translations.floatingWhatsapp.message);
---

<section class="py-section-padding bg-linen overflow-hidden" id="hero">
  <Container class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
    <div class="space-y-6">
      <span
        class="text-terracotta font-label-caps text-label-caps uppercase tracking-[0.2em] block"
      >
        {t.eyebrow}
      </span>
      <h1
        class="font-display-lg text-display-lg-mobile md:text-display-lg text-espresso"
      >
        {t.title}
      </h1>
      <p class="text-soft-espresso font-body-lg max-w-md">
        {t.intro}
      </p>
      <Button
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="w-fit group"
      >
        {t.cta}
        <Icon name="arrow_forward" class="transition-transform group-hover:translate-x-1" />
      </Button>
    </div>
    <div class="relative">
      <div
        class="aspect-[4/5] rounded-lg overflow-hidden bg-parchment border border-hairline"
      >
        <Image
          src={heroPortrait}
          alt={t.imageAlt}
          loading="eager"
          fetchpriority="high"
          class="w-full h-full object-cover"
        />
      </div>
      <!-- Decorative element -->
      <div
        class="absolute -bottom-6 -left-6 w-24 h-24 bg-terracotta opacity-10 rounded-full blur-2xl"
      >
      </div>
    </div>
  </Container>
</section>
