---
import { getTranslations, type Lang } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang).footer;
const socials = t.socials;
---

<footer
  class="bg-surface-container-high py-section-padding px-gutter w-full flex flex-col items-center gap-stack-lg border-t border-hairline"
>
  <div class="flex flex-col items-center gap-4">
    <span class="font-display-lg text-headline-md text-primary">
      Sussana Correa
    </span>
    <div class="flex gap-8">
      {
        socials.map((social) => (
          <a
            class="text-on-surface-variant hover:text-secondary transition-colors font-label-caps uppercase tracking-widest cursor-pointer"
            href={social.href}
          >
            {social.label}
          </a>
        ))
      }
    </div>
  </div>
  <p class="text-on-surface-variant text-body-md opacity-60">
    {t.copyright}
  </p>
</footer>
