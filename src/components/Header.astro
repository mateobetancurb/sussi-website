---
import Container from "./Container.astro";
import Icon from "./Icon.astro";

const links = [
  { label: "Philosophy", href: "#philosophy" },
  { label: "Work", href: "#services" },
  { label: "Strategy", href: "#strategy" },
  { label: "Contact", href: "#contact" },
];
---

<header class="bg-linen w-full top-0 z-50">
  <Container class="flex justify-between items-center py-6">
    <span class="font-display-lg text-headline-sm text-primary tracking-tight">
      Sussana Correa
    </span>
    <div class="hidden md:flex gap-8 items-center">
      {
        links.map((link) => (
          <a
            class="text-on-surface-variant font-label-caps text-label-caps uppercase tracking-widest hover:text-primary transition-colors"
            href={link.href}
          >
            {link.label}
          </a>
        ))
      }
    </div>
    <button class="md:hidden text-primary" aria-label="Abrir menú">
      <Icon name="menu" />
    </button>
  </Container>
</header>
