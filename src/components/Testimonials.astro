---
import { Image } from "astro:assets";
import Container from "./Container.astro";
import Icon from "./Icon.astro";
import testimonialFrame from "../assets/img/testimonial-sabrositas.jpg";

const testimonials = [
  {
    quote:
      "Trabajar con Sussi ha sido un antes y un después. No solo publica, ella entiende mi marca mejor que yo.",
    author: "— Andrea G., Sabrositas",
  },
  {
    quote:
      "Su capacidad para planear a largo plazo nos dio la tranquilidad que necesitábamos para crecer.",
    author: "— Jorge L., MUTA Travel",
  },
  {
    quote:
      "Elegancia, pulcritud y resultados. Sus reportes son claros y siempre traen nuevas ideas.",
    author: "— Mariana V., Hotelería",
  },
  {
    quote:
      "Tiene un ojo para el detalle que es muy difícil de encontrar en el mundo digital de hoy.",
    author: "— Carlos R., CMV Hospital",
  },
];
---

<section class="py-section-padding bg-parchment">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-5">
        <h2 class="font-headline-md text-headline-md text-espresso mb-8">
          Lo que dicen quienes han creado conmigo
        </h2>
        <div
          class="aspect-video bg-linen rounded-lg border border-hairline relative flex items-center justify-center overflow-hidden"
        >
          <Image
            src={testimonialFrame}
            alt="Fotograma de un video testimonio: una emprendedora sonríe en su tienda bien iluminada."
            loading="lazy"
            class="w-full h-full object-cover opacity-80"
          />
          <div
            class="absolute inset-0 flex flex-col items-center justify-center text-center p-6 bg-espresso/20 group cursor-pointer"
          >
            <Icon name="play_circle" class="text-6xl text-linen mb-4" />
            <p class="text-linen font-label-caps uppercase">
              Testimonio: Fundadora Sabrositas
            </p>
          </div>
        </div>
      </div>
      <div class="lg:col-span-7 grid grid-cols-1 md:grid-cols-2 gap-6">
        {
          testimonials.map((testimonial) => (
            <div class="p-8 bg-linen rounded-lg border border-hairline space-y-4">
              <p class="text-body-md italic text-soft-espresso">
                {testimonial.quote}
              </p>
              <p class="font-label-caps text-espresso">{testimonial.author}</p>
            </div>
          ))
        }
      </div>
    </div>
  </Container>
</section>
