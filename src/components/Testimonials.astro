---
import { Image } from "astro:assets";
import Container from "./Container.astro";
import Icon from "./Icon.astro";
import testimonialFrame from "../assets/img/testimonial-sabrositas.jpg";
import { getTranslations, type Lang } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang).testimonials;
const testimonials = t.items;
---

<section class="py-section-padding bg-parchment">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-5">
        <h2 class="font-headline-md text-headline-md text-espresso mb-8">
          {t.heading}
        </h2>
        <div
          class="aspect-video bg-linen rounded-lg border border-hairline relative flex items-center justify-center overflow-hidden"
        >
          <Image
            src={testimonialFrame}
            alt={t.imageAlt}
            loading="lazy"
            class="w-full h-full object-cover opacity-80"
          />
          <div
            class="absolute inset-0 flex flex-col items-center justify-center text-center p-6 bg-espresso/20 group cursor-pointer"
          >
            <Icon name="play_circle" class="text-6xl text-linen mb-4" />
            <p class="text-linen font-label-caps uppercase">
              {t.videoLabel}
            </p>
          </div>
        </div>
      </div>
      <div class="lg:col-span-7 grid grid-cols-1 md:grid-cols-2 gap-6">
        {
          testimonials.map((testimonial) => (
            <div class="p-8 bg-linen rounded-lg border border-hairline space-y-4">
              <p class="text-body-md italic text-soft-espresso">
                {testimonial.quote}
              </p>
              <p class="font-label-caps text-espresso">{testimonial.author}</p>
            </div>
          ))
        }
      </div>
    </div>
  </Container>
</section>
