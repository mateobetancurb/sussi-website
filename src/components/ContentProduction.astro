---
import { Image } from "astro:assets";
import Container from "./Container.astro";
import Button from "./Button.astro";
import Icon from "./Icon.astro";
import ugc1 from "../assets/img/ugc-1.jpg";
import ugc2 from "../assets/img/ugc-2.jpg";
import ugc3 from "../assets/img/ugc-3.jpg";
import ugc4 from "../assets/img/ugc-4.jpg";
import { getTranslations, getWhatsappUrl, type Lang } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const translations = getTranslations(lang);
const t = translations.contentProduction;
const whatsappUrl = getWhatsappUrl(translations.floatingWhatsapp.message);

const clipImages = [ugc1, ugc2, ugc3, ugc4];
const clips = clipImages.map((img, i) => ({ img, alt: t.clipAlts[i] }));
---

<section class="py-section-padding bg-linen">
  <Container>
    <div class="max-w-[760px] mx-auto text-center space-y-6 mb-16">
      <span
        class="text-terracotta font-label-caps text-label-caps uppercase tracking-widest"
      >
        {t.eyebrow}
      </span>
      <h2 class="font-display-lg text-headline-md text-espresso">
        {t.heading}
      </h2>
      <p class="text-soft-espresso font-body-lg">
        {t.intro}
      </p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
      {
        clips.map((clip, index) => (
          <div
            class:list={[
              "aspect-[9/16] bg-parchment rounded-lg overflow-hidden relative group",
              index % 2 === 1 && "mt-8",
            ]}
          >
            <Image
              src={clip.img}
              alt={clip.alt}
              loading="lazy"
              class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
            />
            <div class="absolute inset-0 flex items-center justify-center">
              <Icon
                name="play_circle"
                class="text-white text-4xl opacity-70 group-hover:opacity-100 transition-opacity"
              />
            </div>
          </div>
        ))
      }
    </div>
    <div class="text-center">
      <p class="font-body-md text-soft-espresso mb-6">
        {t.ctaQuestion}
      </p>
      <Button
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="mx-auto w-fit"
      >
        {t.ctaButton} <Icon name="arrow_outward" />
      </Button>
    </div>
  </Container>
</section>
