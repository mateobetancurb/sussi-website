---
import { Image } from "astro:assets";
import Container from "./Container.astro";
import moonarca1 from "../assets/img/archive-moonarca-1.jpg";
import moonarca2 from "../assets/img/archive-moonarca-2.jpg";
import { getTranslations, type Lang } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang).archive;

const brands = ["Brand A", "Brand B", "Brand C"];
---

<section class="py-section-padding bg-parchment">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="font-headline-md text-headline-md text-espresso mb-6">
          {t.heading}
        </h2>
        <div class="space-y-8">
          <div class="border-l-2 border-terracotta pl-6 py-2">
            <h4 class="font-headline-sm text-espresso">{t.moonarcaTitle}</h4>
            <p class="text-soft-espresso font-body-md mt-2">
              {t.moonarcaBody}
            </p>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div class="aspect-[3/4] bg-linen rounded-2xl overflow-hidden">
              <Image
                src={moonarca1}
                alt={t.alts[0]}
                loading="lazy"
                class="w-full h-full object-cover"
              />
            </div>
            <div class="aspect-[3/4] bg-linen rounded-2xl overflow-hidden">
              <Image
                src={moonarca2}
                alt={t.alts[1]}
                loading="lazy"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        </div>
      </div>
      <div class="space-y-4">
        <p class="text-soft-espresso italic font-body-lg">
          {t.quote}
        </p>
        <div class="grid grid-cols-3 gap-2">
          {
            brands.map((brand) => (
              <div class="aspect-square bg-linen opacity-60 rounded-2xl flex items-center justify-center p-4">
                <span class="text-label-caps text-center">{brand}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </Container>
</section>
