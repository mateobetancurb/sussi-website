---
import Container from "./Container.astro";
import Button from "./Button.astro";
import Icon from "./Icon.astro";
import { getTranslations, type Lang } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang).services;

// Structural config (icons + border classes) stays here; copy comes from the
// translation dictionary and is zipped in by index.
const serviceMeta = [
  { icon: "strategy", border: "border-b md:border-b-0 md:border-r border-hairline" },
  { icon: "calendar_today", border: "border-b md:border-b-0 md:border-r border-hairline" },
  { icon: "movie_edit", border: "border-b md:border-b-0" },
  { icon: "analytics", border: "border-b md:border-b-0 md:border-r border-hairline" },
  { icon: "publish", border: "" },
];

const services = serviceMeta.map((meta, i) => ({ ...meta, ...t.items[i] }));
---

<section class="py-section-padding bg-parchment" id="services">
  <Container>
    <div class="max-w-[760px] mx-auto text-center space-y-4 mb-16">
      <h2 class="font-headline-md text-headline-md text-espresso">
        {t.heading}
      </h2>
      <p class="text-soft-espresso font-body-lg">
        {t.intro}
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        services.map((service) => (
          <div class:list={["p-8 space-y-4", service.border]}>
            <Icon name={service.icon} class="text-terracotta" />
            <h3 class="font-headline-sm text-espresso">{service.title}</h3>
            <p class="text-body-md text-soft-espresso">{service.body}</p>
          </div>
        ))
      }
      <!-- CTA Card -->
      <div
        class="p-8 bg-linen rounded-lg border border-hairline flex flex-col justify-center items-center text-center space-y-4"
      >
        <p class="font-body-md italic text-soft-espresso">
          {t.ctaQuestion}
        </p>
        <Button variant="secondary" href="#contact" class="w-full">
          {t.ctaButton} <Icon name="mail" />
        </Button>
      </div>
    </div>
  </Container>
</section>
