---
import type { HTMLAttributes } from "astro/types";

type Variant = "primary" | "secondary";

type Props = HTMLAttributes<"a"> &
  HTMLAttributes<"button"> & {
    variant?: Variant;
  };

const { variant = "primary", href, class: className, ...rest } = Astro.props;

const base =
  "cursor-pointer rounded-full px-8 py-4 font-button text-button transition-all duration-300 active:scale-95 flex items-center justify-center gap-2";

const variants: Record<Variant, string> = {
  primary: "bg-adobe text-linen hover:opacity-90",
  secondary:
    "border border-terracotta text-soft-espresso hover:bg-terracotta hover:text-linen",
};

const classes = [base, variants[variant], className];
// Render as a link when `href` is provided, otherwise a button.
const Tag = (href ? "a" : "button") as "a" | "button";
---

<Tag class:list={classes} href={href} {...rest}>
  <slot />
</Tag>
