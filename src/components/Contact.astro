---
import Button from "./Button.astro";
import Icon from "./Icon.astro";
import WhatsAppIcon from "./WhatsAppIcon.astro";
import { getTranslations, getWhatsappUrl, type Lang } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const translations = getTranslations(lang);
const t = translations.contact;
const whatsappUrl = getWhatsappUrl(translations.floatingWhatsapp.message);
---

<section class="py-section-padding bg-linen border-t border-hairline" id="contact">
  <div class="max-w-2xl mx-auto px-6 text-center">
    <div class="mb-12">
      <span class="text-terracotta mb-4 block" aria-hidden="true">✦</span>
      <h2
        class="font-display-lg text-display-lg-mobile md:text-display-lg text-espresso mb-6"
      >
        {t.heading}
      </h2>
      <p class="text-soft-espresso font-body-lg">
        {t.intro}
      </p>
    </div>
    <div class="flex flex-col md:flex-row gap-4 justify-center items-center">
      <Button
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={translations.floatingWhatsapp.ariaLabel}
        class="w-full md:w-auto px-12"
      >
        {t.whatsapp} <WhatsAppIcon />
      </Button>
      <Button
        variant="secondary"
        href="https://www.instagram.com/sussanacorreac/"
        target="_blank"
        rel="noopener noreferrer"
        class="w-full md:w-auto px-12"
      >
        {t.instagram} <Icon name="photo_camera" />
      </Button>
    </div>
  </div>
</section>
